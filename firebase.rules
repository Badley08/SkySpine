rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /scores/{scoreId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'distance', 'timestamp'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 20
        && request.resource.data.distance is number
        && request.resource.data.distance >= 0
        && request.resource.data.distance <= 1000000
        && request.resource.data.timestamp is number;
      allow update, delete: if false;
    }

    match /ghost/{ghostId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'distance', 'path', 'timestamp'])
        && request.resource.data.name is string
        && request.resource.data.distance is number
        && request.resource.data.path is string;
      allow update, delete: if false;
    }

    match /quests/{questId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasAll(['pilotId', 'questId', 'progress', 'completed'])
        && request.resource.data.pilotId is string
        && request.resource.data.questId is string
        && request.resource.data.progress is number
        && request.resource.data.completed is bool;
    }
  }
}
